generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PAID
  CONFIRMED
  FULFILLED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Seller {
  id           String            @id @default(cuid())
  email        String?           @unique
  passwordHash String
  name         String
  phone        String            @unique
  isVerified   Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  store        Store?
  products     Product[]
  orders       Order[]
  messages     WhatsappMessage[]
   sessions     SellerSession[]
  plugins      SellerPlugin[]  
}

model Store {
  id          String            @id @default(cuid())
  sellerId    String            @unique
  slug        String            @unique
  name        String
  description String?
  logoUrl     String?
  city        String?
  category    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  seller      Seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  products    Product[]
  orders      Order[]
  messages    WhatsappMessage[]
}

model Product {
  id          String      @id @default(cuid())
  sellerId    String
  storeId     String
  name        String
  description String?
  price       Float
  currency    String      @default("USD")
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  seller      Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  stockQty    Int         @default(0)
  images      ProductImage[]

  @@index([sellerId])
  @@index([storeId])
}

model Order {
  id            String       @id @default(cuid())
  sellerId      String
  storeId       String
  status        OrderStatus  @default(PENDING)
  customerName  String
  customerPhone String
  customerEmail String?
  totalAmount   Float
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  seller        Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  store         Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  payment       Payment?
  messages      WhatsappMessage[]
  orderNumber String? @unique            
  deliveryCode String? @unique            
  buyerId      String?             
  deliveryAddress String?
  notes        String?            
  buyer  Buyer? @relation(fields: [buyerId], references: [id])
  delivery     Delivery?  
  
  @@index([sellerId])
  @@index([storeId])
  @@index([buyerId]) 
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  lineTotal Float
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id               String        @id @default(cuid())
  orderId          String        @unique
  provider         String
  amount           Float
  currency         String
  gatewayReference String?
  status           PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model WhatsappMessage {
  id         String           @id @default(cuid())
  sellerId   String?
  storeId    String?
  orderId    String?
  direction  MessageDirection
  toNumber   String?
  fromNumber String?
  content    String
  status     String?
  createdAt  DateTime         @default(now())
  seller     Seller?          @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  store      Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  order      Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([sellerId])
  @@index([storeId])
  @@index([orderId])
}

model BotSession {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  state       String   @default("IDLE")
  context     Json     @default("{}")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

model Buyer {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  fullName    String?
  city        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model OtpCode {
  id          String   @id @default(cuid())
  phoneNumber String
  code        String
  purpose     OtpPurpose
  isUsed      Boolean  @default(false)
  attempts    Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([phoneNumber, purpose])
}

enum OtpPurpose {
  SELLER_LOGIN
  SELLER_REGISTER
  BUYER_ORDER
  RIDER_LOGIN
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Rider {
  id              String       @id @default(cuid())
  phoneNumber     String       @unique
  fullName        String
  nationalId      String       @unique
  city            String
  vehicleType     VehicleType
  isVerified      Boolean      @default(false)
  isOnline        Boolean      @default(false)
  rating          Float        @default(5.0)
  totalDeliveries Int          @default(0)
  createdAt       DateTime     @default(now())
  deliveries      Delivery[]
  earnings        RiderEarning[]
}

enum VehicleType {
  BICYCLE
  MOTORBIKE
  CAR
  WALKING
}

model Delivery {
  id             String         @id @default(cuid())
  orderId        String         @unique
  riderId        String?
  pickupAddress  String
  dropoffAddress String
  distanceKm     Float?
  feeUsd         Float
  platformCut    Float
  riderPayout    Float
  status         DeliveryStatus @default(LOOKING_FOR_RIDER)
  assignedAt     DateTime?
  pickedUpAt     DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  order          Order          @relation(fields: [orderId], references: [id])
  rider          Rider?         @relation(fields: [riderId], references: [id])
  earnings  RiderEarning[]
}

enum DeliveryStatus {
  LOOKING_FOR_RIDER
  RIDER_ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

model RiderEarning {
  id         String        @id @default(cuid())
  riderId    String
  deliveryId String?
  delivery  Delivery? @relation(fields: [deliveryId], references: [id])
  amountUsd  Float
  type       EarningType
  status     EarningStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  rider      Rider         @relation(fields: [riderId], references: [id])
}

enum EarningType {
  DELIVERY_PAYOUT
  BONUS
  WITHDRAWAL
}

enum EarningStatus {
  PENDING
  PAID
  CANCELLED
}

model Plugin {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  description String?
  priceUsd    Float          @default(0)
  isFree      Boolean        @default(false)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  sellers     SellerPlugin[]
}

model SellerPlugin {
  id          String   @id @default(cuid())
  sellerId    String
  pluginId    String
  isActive    Boolean  @default(true)
  config      Json?
  installedAt DateTime @default(now())
  seller      Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  plugin      Plugin   @relation(fields: [pluginId], references: [id])

  @@unique([sellerId, pluginId])
}

model SellerSession {
  id           String   @id @default(cuid())
  sellerId     String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  seller       Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

// Useful for your admin console
// Tracks everything that happens

model AuditLog {
  id         String   @id @default(cuid())
  actorType  String?  // "seller" | "admin" | "system"
  actorId    String?
  action     String   // "order.created" | "seller.verified"
  entityType String?  // "order" | "seller" | "product"
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
}

model ShopifyMerchant {
  id                 String    @id @default(cuid())
  shop               String    @unique
  accessToken        String
  scope              String
  storeSlug          String?
  storeName          String?
  whatsappConnected Boolean   @default(false)
  whatsappNumber    String?
  whatsappPhoneId   String?
  whatsappToken      String?
  instagramConnected Boolean   @default(false)
  instagramToken     String?
  instagramAccountId String?
  instagramUsername   String?
  messengerConnected Boolean   @default(false)
  messengerToken     String?
  messengerPageId    String?
  messengerPageName  String?
  isActive           Boolean   @default(true)
  installedAt        DateTime  @default(now())
  uninstalledAt      DateTime?
  
  // Billing fields
  planName           String?   // "BASIC" | "PRO"
  planStatus         String?   // "ACTIVE" | "PENDING" | "EXPIRED"
  planChargeId       String?   // Shopify AppSubscription GID
  planTrialExpiresAt DateTime?

  updatedAt          DateTime  @updatedAt

  @@index([shop])
}

model CommentTrigger {
  id              String   @id @default(cuid())
  merchantId      String
  keyword         String
  replyComment    Boolean  @default(true) // Whether to send public reply
  templateMessage String?  @db.Text // Custom DM string with {{variables}}
  isActive        Boolean  @default(true)
  triggerCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([merchantId, keyword])
  @@index([merchantId])
}

model CommentDmLog {
  id          String   @id @default(cuid())
  merchantId  String
  commenterId String
  mediaId     String
  keyword     String
  sentAt      DateTime @default(now())

  @@unique([merchantId, commenterId, mediaId])
}

model PostProductMapping {
  id               String   @id @default(cuid())
  merchantId       String
  platform         String   // "instagram" | "facebook"
  postUrl          String?  // Original post URL (for merchant reference)
  mediaId          String   // Instagram media ID or Facebook post_id
  shopifyProductId String   // Shopify product ID to link to
  productTitle     String?  // Cached product title for quick display
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([merchantId, mediaId])
  @@index([merchantId])
  @@index([mediaId])
}