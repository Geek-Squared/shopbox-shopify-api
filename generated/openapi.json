  "info": {
    "title": "Shopbox API",
    "description": "Shopbox API",
    "version": "0.0.2",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "seller@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "name": {
            "type": "string",
            "minLength": 2
          },
          "storeSlug": {
            "type": "string",
            "pattern": "^[a-z0-9-]{3,32}$"
          },
          "phone": {
            "type": "string",
            "example": "+1234567890"
          }
        },
        "required": [
          "password",
          "name",
          "storeSlug",
          "phone"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+1234567890"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        },
        "required": [
          "phone",
          "password"
        ]
      },
      "LogoutDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "OtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        },
        "required": [
          "phone"
        ]
      },
      "UpdateSellerDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "UpdateStoreDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "logoUrl": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        }
      },
      "WhatsappWebhookDto": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        }
      },
      "SendWhatsappDto": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "template": {
            "type": "string"
          },
          "sellerId": {
            "type": "string"
          },
          "orderId": {
            "type": "string"
          }
        },
        "required": [
          "to"
        ]
      },
      "CreateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "minimum": 0
          },
          "currency": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "price"
        ]
      },
      "UpdateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "minimum": 0
          },
          "currency": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "CreateOrderItemDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 1
          }
        },
        "required": [
          "productId",
          "quantity"
        ]
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "storeSlug": {
            "type": "string"
          },
          "customerName": {
            "type": "string"
          },
          "customerPhone": {
            "type": "string"
          },
          "customerEmail": {
            "type": "string"
          },
          "items": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateOrderItemDto"
            }
          }
        },
        "required": [
          "storeSlug",
          "customerName",
          "customerPhone",
          "items"
        ]
      },
      "UpdateOrderDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "PAID",
              "CONFIRMED",
              "FULFILLED",
              "CANCELLED"
            ]
          },
          "customerName": {
            "type": "string"
          },
          "customerPhone": {
            "type": "string"
          }
        }
      },
      "InitiatePaymentDto": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "enum": [
              "PAYNOW",
              "INNBUCKS"
            ]
          }
        },
        "required": [
          "orderId",
          "provider"
        ]
      },
      "VerifyPaymentDto": {
        "type": "object",
        "properties": {
          "paymentId": {
            "type": "string"
          },
          "gatewayReference": {
            "type": "string"
          }
        },
        "required": [
          "paymentId",
          "gatewayReference"
        ]
      },
      "PaymentWebhookDto": {
        "type": "object",
        "properties": {
          "paymentId": {
            "type": "string"
          },
          "gatewayReference": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        }
      },
      "DeliveryDto": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string"
          },
          "address": {
            "type": "string"
          }
        },
        "required": [
          "orderId"
        ]
      },
      "RidersDto": {
        "type": "object",
        "properties": {
          "zone": {
            "type": "string"
          }
        }
      }
    }
  }
}